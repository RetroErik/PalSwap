  1233                                      ; Free TSR memory block (ES = segment)
  1234 0000076A B449                        mov ah, 0x49
  1235 0000076C CD21                        int 0x21
  1236                                  
  1237 0000076E 0E                          push cs
  1238 0000076F 1F                          pop ds                     ; ensure DS = CS for print_string
  1239                                  
  1240                                      ; On VGA, re-enable default palette loading
