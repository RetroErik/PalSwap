     1                                  ; ============================================================================
     2                                  ; PalSwapT.ASM - CGA Palette Override TSR with Live Hotkeys
     3                                  ; Written for NASM - 8086 compatible (runs on any DOS PC)
     4                                  ; By Retro Erik - 2026 using VS Code with GitHub Copilot
     5                                  ; Version 3.0 - TSR with ScrollLock hotkeys
     6                                  ; ============================================================================
     7                                  ;
     8                                  ; Combines the full palette engine of PalSwap.asm with a TSR that hooks
     9                                  ; both INT 10h (video mode change) and INT 09h (keyboard) so you can:
    10                                  ;   - Survive CGA mode resets (palette re-applied after every mode 4/5 set)
    11                                  ;   - Switch presets LIVE while a game is running (ScrollLock + 1..5)
    12                                  ;   - Adjust brightness, saturation, pop on the fly (ScrollLock + arrows/P/R)
    13                                  ;
    14                                  ; HOTKEY SYSTEM:
    15                                  ;   Turn ScrollLock ON to activate palette edit mode (LED = indicator).
    16                                  ;   While ScrollLock is ON:
    17                                  ;     1..5         Load preset 1-5 (Arcade, Sierra, C64, Red/Green, Red/Blue)
    18                                  ;     P            Toggle Pop (saturation + contrast boost)
    19                                  ;     R            Reset to default CGA palette
    20                                  ;     Up / Down    Brighten / Dim (+/-8 per step, max 3 steps)
    21                                  ;     Left / Right Less vivid / More vivid (saturation, max 3 steps)
    22                                  ;   Turn ScrollLock OFF to return to normal — all keys pass through.
    23                                  ;   (ScrollLock is never used by CGA-era games, so zero interference.)
    24                                  ;
    25                                  ; HOW IT WORKS:
    26                                  ;   1. You run PalSwapT [/1..5 | file.txt | /c:... | /b:...] before the game.
    27                                  ;   2. PalSwapT loads the palette, hooks INT 09h + INT 10h, stays resident.
    28                                  ;   3. When the game calls INT 10h AH=00h AL=04h/05h (set CGA mode 4/5):
    29                                  ;        a. The original INT 10h handler runs first (sets the hardware mode).
    30                                  ;        b. Our hook immediately re-programs the VGA DAC or EGA ATC.
    31                                  ;   4. While running, press ScrollLock then 1-5/P/R/arrows to adjust live.
    32                                  ;   5. Run "PalSwapT /U" to uninstall.
    33                                  ;
    34                                  ; VGA path:
    35                                  ;   Table-driven DAC write using color_to_dac[] for conflict-free routing.
    36                                  ;   ATC[0-3] = 0, 1, 8, 9  — avoids DAC entry conflicts between CGA palette
    37                                  ;   variants.  Also calls INT 10h AX=1201h BL=31h to disable BIOS palette
    38                                  ;   reload.  Belt-and-suspenders: disable flag + hook re-apply.
    39                                  ;
    40                                  ; EGA path:
    41                                  ;   Converts RGB to nearest EGA 6-bit values. Builds 16-entry atc_shadow[]
    42                                  ;   covering all CGA palette routing variants.  Re-applied via ATC ports.
    43                                  ;
    44                                  ; CGA mode 4 pixel -> DAC entry mapping (all 16 entries programmed):
    45                                  ;   DAC 0  = color 0 (background)
    46                                  ;   DAC 1  = color 1 (our ATC)     DAC 8  = color 2 (our ATC)
    47                                  ;   DAC 2  = color 1 (pal0 low)    DAC 9  = color 3 (our ATC)
    48                                  ;   DAC 3  = color 1 (pal1 low)    DAC 10 = color 1 (pal0 high)
    49                                  ;   DAC 4  = color 2 (pal0 low)    DAC 11 = color 1 (pal1 high)
    50                                  ;   DAC 5  = color 2 (pal1 low)    DAC 12 = color 2 (pal0 high)
    51                                  ;   DAC 6  = color 3 (pal0 low)    DAC 13 = color 2 (pal1 high)
    52                                  ;   DAC 7  = color 3 (pal1 low)    DAC 14 = color 3 (pal0 high)
    53                                  ;                                   DAC 15 = color 3 (pal1 high)
    54                                  ;
    55                                  ; IMPORTANT - far-pointer layout in resident data:
    56                                  ;   orig_int10_ofs MUST come before orig_int10_seg in memory because
    57                                  ;   "jmp/call far [mem]" reads offset then segment.
    58                                  ;   Same for orig_int09_ofs / orig_int09_seg.
    59                                  ;
    60                                  ; TSR SIZE:
    61                                  ;   Computed at runtime as  (offset_of_tsr_end + 15) / 16  paragraphs.
    62                                  ;   ORG 0x100 means label offsets already include the 256-byte PSP.
    63                                  ;
    64                                  ; Usage: PalSwapT [file.txt] [/1..5] [/c:c1,c2,c3] [/b:color]
    65                                  ;                 [/P] [/V:+|-] [/D:+|-] [/R] [/U] [/?]
    66                                  ;
    67                                  ; ============================================================================
    68                                  
    69                                  [BITS 16]
    70                                  [ORG 0x100]
    71                                  CPU 8086
    72                                  
    73                                  ; ============================================================================
    74                                  ; Constants
    75                                  ; ============================================================================
    76                                  VGA_DAC_WRITE_IDX   equ 0x3C8
    77                                  VGA_DAC_DATA        equ 0x3C9
    78                                  ATC_ADDR_DATA       equ 0x3C0
    79                                  INPUT_STATUS_1      equ 0x3DA
    80                                  
    81                                  CONFIG_SIZE         equ 12          ; 4 colors × 3 bytes
    82                                  PALETTE_ENTRIES     equ 4
    83                                  TEXT_BUF_SIZE       equ 512
    84                                  
    85                                  ; Keyboard scan codes
    86                                  SCAN_1              equ 0x02
    87                                  SCAN_5              equ 0x06
    88                                  SCAN_P              equ 0x19
    89                                  SCAN_R              equ 0x13
    90                                  SCAN_UP             equ 0x48
    91                                  SCAN_DOWN           equ 0x50
    92                                  SCAN_LEFT           equ 0x4B
    93                                  SCAN_RIGHT          equ 0x4D
    94                                  
    95                                  ; BIOS keyboard flag bits at 0040:0017h
    96                                  SCROLLLOCK_BIT      equ 0x10        ; bit 4 = ScrollLock active
    97                                  
    98                                  ; Adjustment limits
    99                                  MAX_BRIGHT_LEVEL    equ 3
   100                                  MAX_VIVID_LEVEL     equ 3
   101                                  
   102                                  ; ============================================================================
   103                                  ; Jump over resident section to installer
   104                                  ; ============================================================================
   105 00000000 E90705                  jmp main
   106                                  
   107                                  ; ============================================================================
   108                                  ; =====================  RESIDENT SECTION  ===================================
   109                                  ; ============================================================================
   110                                  ; Everything from here to tsr_end stays in memory after going TSR.
   111                                  ; ============================================================================
   112                                  
   113                                  ; --- TSR Signature (7 bytes) - used for detection/uninstall ---
   114 00000003 50616C53776170          tsr_sig:            db 'PalSwap'
   115                                  
   116                                  ; --- Original interrupt vectors (far pointers: offset THEN segment) ---
   117 0000000A 0000                    orig_int10_ofs:     dw 0
   118 0000000C 0000                    orig_int10_seg:     dw 0
   119 0000000E 0000                    orig_int09_ofs:     dw 0
   120 00000010 0000                    orig_int09_seg:     dw 0
   121                                  
   122                                  ; --- Video adapter type: 0=none, 1=EGA, 2=VGA ---
   123 00000012 00                      video_type:         db 0
   124                                  
   125                                  ; --- Adjustment state ---
   126 00000013 00                      adj_brightness:     db 0            ; signed: -3..+3 (each step = ±8)
   127 00000014 00                      adj_vivid:          db 0            ; signed: -3..+3
   128 00000015 00                      adj_pop:            db 0            ; 0=off, 1=on (toggle)
   129                                  
   130                                  ; --- Base palette: the original colors loaded from preset/file/cmdline.
   131                                  ;     Never modified by hotkeys. Adjustments are applied on top of this. ---
   132                                  base_palette:
   133 00000016 000000                      db 0,  0,  0               ; color 0: Black
   134 00000019 002A3F                      db 0, 42, 63               ; color 1: Cyan
   135 0000001C 2A002A                      db 42,  0, 42              ; color 2: Magenta
   136 0000001F 3F3F3F                      db 63, 63, 63              ; color 3: White
   137                                  
   138                                  ; --- Active palette: recomputed from base + adjustments, written to HW ---
   139                                  palette_rgb:
   140 00000022 000000                      db 0,  0,  0
   141 00000025 002A3F                      db 0, 42, 63
   142 00000028 2A002A                      db 42,  0, 42
   143 0000002B 3F3F3F                      db 63, 63, 63
   144                                  
   145                                  ; --- EGA ATC shadow table (16 bytes, rebuilt on every adjustment) ---
   146 0000002E 00<rep 10h>             atc_shadow:         times 16 db 0
   147                                  
   148                                  ; --- Resident lookup tables ---
   149                                  
   150                                  ; Maps DAC entry 0-15 to user color index 0-3 (conflict-free routing)
   151                                  color_to_dac:
   152 0000003E 000101010202030302-         db 0, 1, 1, 1, 2, 2, 3, 3, 2, 3, 1, 1, 2, 2, 3, 3
   152 00000047 03010102020303     
   153                                  
   154                                  ; ATC[0-3] = 0,1,8,9 (conflict-free), ATC[4-15] = standard text values
   155                                  vga_atc_init:
   156 0000004E 000108090405140738-         db 0, 1, 8, 9, 4, 5, 0x14, 7, 0x38, 0x39, 0x3A, 0x3B, 0x3C, 0x3D, 0x3E, 0x3F
   156 00000057 393A3B3C3D3E3F     
   157                                  
   158                                  ; Default EGA ATC register values for the 16 CGA colors
   159                                  cga_ega_default:
   160 0000005E 0001020304051407            db 0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x14, 0x07
   161 00000066 38393A3B3C3D3E3F            db 0x38, 0x39, 0x3A, 0x3B, 0x3C, 0x3D, 0x3E, 0x3F
   162                                  
   163                                  ; 5 preset palettes + fallback (resident for hotkey switching)
   164                                  res_preset_fallback:
   165 0000006E 000000002A3F2A002A-         db 0,  0,  0,    0, 42, 63,   42,  0, 42,   63, 63, 63
   165 00000077 3F3F3F             
   166                                  res_preset_1:                       ; Arcade Vibrant
   167 0000007A 000000091B3F3F0909-         db 0,  0,  0,    9, 27, 63,   63,  9,  9,   63, 45, 27
   167 00000083 3F2D1B             
   168                                  res_preset_2:                       ; Sierra Natural
   169 00000086 000000092424241209-         db 0,  0,  0,    9, 36, 36,   36, 18,  9,   63, 45, 36
   169 0000008F 3F2D24             
   170                                  res_preset_3:                       ; C64-inspired
   171 00000092 000000121B3F361B09-         db 0,  0,  0,   18, 27, 63,   54, 27,  9,   63, 54, 36
   171 0000009B 3F3624             
   172                                  res_preset_4:                       ; CGA Red/Green/White
   173 0000009E 0000003F0909093F09-         db 0,  0,  0,   63,  9,  9,    9, 63,  9,   63, 63, 63
   173 000000A7 3F3F3F             
   174                                  res_preset_5:                       ; CGA Red/Blue/White
   175 000000AA 0000003F000000003F-         db 0,  0,  0,   63,  0,  0,    0,  0, 63,   63, 63, 63
   175 000000B3 3F3F3F             
   176                                  
   177                                  ; DAC table workspace for VGA (16 entries × 3 bytes = 48 bytes)
   178 000000B6 00<rep 30h>             dac_table:          times 48 db 0
   179                                  
   180                                  ; EGA temporary workspace (4 bytes)
   181 000000E6 00<rep 4h>              ega_tmp:            times 4 db 0
   182                                  
   183                                  ; ============================================================================
   184                                  ; INT 10h HOOK — Re-apply palette after CGA mode 4/5 set
   185                                  ; ============================================================================
   186                                  tsr_int10:
   187 000000EA 80FC00                      cmp ah, 0x00
   188 000000ED 7508                        jne .chain
   189 000000EF 3C04                        cmp al, 0x04
   190 000000F1 7409                        je .cga_mode
   191 000000F3 3C05                        cmp al, 0x05
   192 000000F5 7405                        je .cga_mode
   193                                  
   194                                  .chain:
   195 000000F7 2EFF2E[0A00]                jmp far [cs:orig_int10_ofs]
   196                                  
   197                                  .cga_mode:
   198                                      ; Let the original handler set the mode first
   199 000000FC 9C                          pushf
   200 000000FD 2EFF1E[0A00]                call far [cs:orig_int10_ofs]
   201                                      ; Now re-apply our palette
   202 00000102 2E803E[1200]02              cmp byte [cs:video_type], 2
   203 00000108 7409                        je .do_vga
   204 0000010A 2E803E[1200]01              cmp byte [cs:video_type], 1
   205 00000110 7405                        je .do_ega
   206 00000112 CF                          iret
   207                                  .do_vga:
   208 00000113 E8CD01                      call apply_palette_vga
   209 00000116 CF                          iret
   210                                  .do_ega:
   211 00000117 E84102                      call apply_palette_ega
   212 0000011A CF                          iret
   213                                  
   214                                  ; ============================================================================
   215                                  ; INT 09h HOOK — ScrollLock-gated hotkeys for live palette adjustment
   216                                  ; ============================================================================
   217                                  tsr_int09:
   218 0000011B 50                          push ax
   219 0000011C 1E                          push ds
   220                                  
   221                                      ; Read scan code from keyboard controller
   222 0000011D E460                        in al, 0x60
   223                                  
   224                                      ; If this IS the ScrollLock key itself, let the BIOS handle it
   225                                      ; (so the LED toggles normally) — don't intercept
   226 0000011F 3C46                        cmp al, 0x46               ; ScrollLock make code
   227 00000121 7503E9B500                  je .chain_kb
   228                                  
   229                                      ; Check if it's a key release (bit 7 set) — ignore releases
   230 00000126 A880                        test al, 0x80
   231 00000128 7403E9AE00                  jnz .chain_kb
   232                                  
   233                                      ; Check ScrollLock state in BIOS keyboard flags
   234 0000012D B84000                      mov ax, 0x0040
   235 00000130 8ED8                        mov ds, ax
   236 00000132 F606170010                  test byte [0x0017], SCROLLLOCK_BIT
   237 00000137 7503E99F00                  jz .chain_kb               ; ScrollLock off → pass through
   238                                  
   239                                      ; ScrollLock is ON — check for our hotkeys
   240 0000013C 88C4                        mov ah, al                 ; save scan code in AH
   241                                  
   242                                      ; Preset keys 1-5
   243 0000013E 80FC02                      cmp ah, SCAN_1
   244 00000141 720D                        jb .check_special
   245 00000143 80FC06                      cmp ah, SCAN_5
   246 00000146 7708                        ja .check_special
   247                                      ; AH = 02h..06h → preset 1..5
   248 00000148 80EC02                      sub ah, SCAN_1             ; AH = 0..4 = preset index
   249 0000014B E89400                      call hotkey_load_preset
   250 0000014E EB7A                        jmp .swallow
   251                                  
   252                                  .check_special:
   253 00000150 80FC19                      cmp ah, SCAN_P
   254 00000153 741B                        je .do_pop
   255 00000155 80FC13                      cmp ah, SCAN_R
   256 00000158 7421                        je .do_reset
   257 0000015A 80FC48                      cmp ah, SCAN_UP
   258 0000015D 7423                        je .do_bright_up
   259 0000015F 80FC50                      cmp ah, SCAN_DOWN
   260 00000162 7430                        je .do_bright_dn
   261 00000164 80FC4D                      cmp ah, SCAN_RIGHT
   262 00000167 743D                        je .do_vivid_up
   263 00000169 80FC4B                      cmp ah, SCAN_LEFT
   264 0000016C 744A                        je .do_vivid_dn
   265 0000016E EB6B                        jmp .chain_kb              ; not our key → pass through
   266                                  
   267                                  .do_pop:
   268 00000170 2E8036[1500]01              xor byte [cs:adj_pop], 1  ; toggle 0↔1
   269 00000176 E8DB00                      call recompute_and_apply
   270 00000179 EB4F                        jmp .swallow
   271                                  
   272                                  .do_reset:
   273                                      ; Load fallback palette, reset all adjustments
   274 0000017B B400                        mov ah, 0                  ; preset index for fallback = special
   275 0000017D E8A100                      call hotkey_load_fallback
   276 00000180 EB48                        jmp .swallow
   277                                  
   278                                  .do_bright_up:
   279 00000182 2E803E[1300]03              cmp byte [cs:adj_brightness], MAX_BRIGHT_LEVEL
   280 00000188 7D40                        jge .swallow               ; already at max
   281 0000018A 2EFE06[1300]                inc byte [cs:adj_brightness]
   282 0000018F E8C200                      call recompute_and_apply
   283 00000192 EB36                        jmp .swallow
   284                                  
   285                                  .do_bright_dn:
   286 00000194 2E803E[1300]FD              cmp byte [cs:adj_brightness], -MAX_BRIGHT_LEVEL
   287 0000019A 7E2E                        jle .swallow               ; already at min
   288 0000019C 2EFE0E[1300]                dec byte [cs:adj_brightness]
   289 000001A1 E8B000                      call recompute_and_apply
   290 000001A4 EB24                        jmp .swallow
   291                                  
   292                                  .do_vivid_up:
   293 000001A6 2E803E[1400]03              cmp byte [cs:adj_vivid], MAX_VIVID_LEVEL
   294 000001AC 7D1C                        jge .swallow
   295 000001AE 2EFE06[1400]                inc byte [cs:adj_vivid]
   296 000001B3 E89E00                      call recompute_and_apply
   297 000001B6 EB12                        jmp .swallow
   298                                  
   299                                  .do_vivid_dn:
   300 000001B8 2E803E[1400]FD              cmp byte [cs:adj_vivid], -MAX_VIVID_LEVEL
   301 000001BE 7E0A                        jle .swallow
   302 000001C0 2EFE0E[1400]                dec byte [cs:adj_vivid]
   303 000001C5 E88C00                      call recompute_and_apply
   304 000001C8 EB00                        jmp .swallow
   305                                  
   306                                  .swallow:
   307                                      ; Acknowledge keystroke: toggle port 61h bit 7 + send EOI to PIC
   308 000001CA E461                        in al, 0x61
   309 000001CC 0C80                        or al, 0x80
   310 000001CE E661                        out 0x61, al
   311 000001D0 247F                        and al, 0x7F
   312 000001D2 E661                        out 0x61, al
   313 000001D4 B020                        mov al, 0x20
   314 000001D6 E620                        out 0x20, al
   315 000001D8 1F                          pop ds
   316 000001D9 58                          pop ax
   317 000001DA CF                          iret
   318                                  
   319                                  .chain_kb:
   320 000001DB 1F                          pop ds
   321 000001DC 58                          pop ax
   322 000001DD 2EFF2E[0E00]                jmp far [cs:orig_int09_ofs]
   323                                  
   324                                  ; ============================================================================
   325                                  ; hotkey_load_preset — Load preset by index (AH = 0..4)
   326                                  ; Resets adjustments and recomputes.
   327                                  ; ============================================================================
   328                                  hotkey_load_preset:
   329 000001E2 50                          push ax
   330 000001E3 51                          push cx
   331 000001E4 56                          push si
   332 000001E5 57                          push di
   333 000001E6 06                          push es
   334                                  
   335 000001E7 0E                          push cs
   336 000001E8 07                          pop es
   337                                  
   338                                      ; Calculate source: res_preset_1 + AH * 12
   339 000001E9 88E0                        mov al, ah
   340 000001EB 30E4                        xor ah, ah
   341 000001ED B10C                        mov cl, 12
   342 000001EF F6E1                        mul cl                     ; AX = preset_index * 12
   343 000001F1 BE[7A00]                    mov si, res_preset_1
   344 000001F4 01C6                        add si, ax
   345                                  
   346                                      ; Copy 12 bytes to base_palette
   347 000001F6 BF[1600]                    mov di, base_palette
   348 000001F9 B90C00                      mov cx, 12
   349                                  .copy:
   350 000001FC 2E8A04                      mov al, [cs:si]
   351 000001FF 2E8805                      mov [cs:di], al
   352 00000202 46                          inc si
   353 00000203 47                          inc di
   354 00000204 E2F6                        loop .copy
   355                                  
   356                                      ; Reset adjustments
   357 00000206 2EC606[1300]00              mov byte [cs:adj_brightness], 0
   358 0000020C 2EC606[1400]00              mov byte [cs:adj_vivid], 0
   359 00000212 2EC606[1500]00              mov byte [cs:adj_pop], 0
   360                                  
   361 00000218 07                          pop es
   362 00000219 5F                          pop di
   363 0000021A 5E                          pop si
   364 0000021B 59                          pop cx
   365 0000021C 58                          pop ax
   366 0000021D E83400                      call recompute_and_apply
   367 00000220 C3                          ret
   368                                  
   369                                  ; ============================================================================
   370                                  ; hotkey_load_fallback — Reset to default CGA palette
   371                                  ; ============================================================================
   372                                  hotkey_load_fallback:
   373 00000221 51                          push cx
   374 00000222 56                          push si
   375 00000223 57                          push di
   376 00000224 06                          push es
   377                                  
   378 00000225 0E                          push cs
   379 00000226 07                          pop es
   380                                  
   381 00000227 BE[6E00]                    mov si, res_preset_fallback
   382 0000022A BF[1600]                    mov di, base_palette
   383 0000022D B90C00                      mov cx, 12
   384                                  .copy:
   385 00000230 2E8A04                      mov al, [cs:si]
   386 00000233 2E8805                      mov [cs:di], al
   387 00000236 46                          inc si
   388 00000237 47                          inc di
   389 00000238 E2F6                        loop .copy
   390                                  
   391 0000023A 2EC606[1300]00              mov byte [cs:adj_brightness], 0
   392 00000240 2EC606[1400]00              mov byte [cs:adj_vivid], 0
   393 00000246 2EC606[1500]00              mov byte [cs:adj_pop], 0
   394                                  
   395 0000024C 07                          pop es
   396 0000024D 5F                          pop di
   397 0000024E 5E                          pop si
   398 0000024F 59                          pop cx
   399 00000250 E80100                      call recompute_and_apply
   400 00000253 C3                          ret
   401                                  
   402                                  ; ============================================================================
   403                                  ; recompute_and_apply — Rebuild palette_rgb from base + adjustments, then
   404                                  ;                       write to hardware (VGA DAC or EGA ATC).
   405                                  ;
   406                                  ; Pipeline:  base → copy to palette_rgb
   407                                  ;            → apply vivid (N times boost or mute)
   408                                  ;            → if pop: saturation_boost + contrast_boost
   409                                  ;            → apply brightness (adj × 8, clamped)
   410                                  ;            → rebuild EGA atc_shadow if needed
   411                                  ;            → write to hardware
   412                                  ; ============================================================================
   413                                  recompute_and_apply:
   414 00000254 50                          push ax
   415 00000255 53                          push bx
   416 00000256 51                          push cx
   417 00000257 52                          push dx
   418 00000258 56                          push si
   419 00000259 57                          push di
   420 0000025A 06                          push es
   421                                  
   422 0000025B 0E                          push cs
   423 0000025C 07                          pop es
   424                                  
   425                                      ; Step 1: Copy base_palette → palette_rgb
   426 0000025D BE[1600]                    mov si, base_palette
   427 00000260 BF[2200]                    mov di, palette_rgb
   428 00000263 B90C00                      mov cx, 12
   429                                  .rc_copy:
   430 00000266 2E8A04                      mov al, [cs:si]
   431 00000269 2E8805                      mov [cs:di], al
   432 0000026C 46                          inc si
   433 0000026D 47                          inc di
   434 0000026E E2F6                        loop .rc_copy
   435                                  
   436                                      ; Step 2: Vivid adjustment (-3..+3 steps of saturation boost/mute)
   437 00000270 2EA0[1400]                  mov al, [cs:adj_vivid]
   438 00000274 84C0                        test al, al
   439 00000276 7418                        jz .rc_pop_check
   440 00000278 780B                        js .rc_vivid_mute
   441                                      ; Positive: apply saturation boost N times
   442 0000027A 88C1                        mov cl, al
   443 0000027C 30ED                        xor ch, ch
   444                                  .rc_vivid_boost_loop:
   445 0000027E E8E701                      call res_saturation_boost
   446 00000281 E2FB                        loop .rc_vivid_boost_loop
   447 00000283 EB0B                        jmp .rc_pop_check
   448                                  .rc_vivid_mute:
   449                                      ; Negative: apply saturation mute N times
   450 00000285 F6D8                        neg al
   451 00000287 88C1                        mov cl, al
   452 00000289 30ED                        xor ch, ch
   453                                  .rc_vivid_mute_loop:
   454 0000028B E81F02                      call res_saturation_mute
   455 0000028E E2FB                        loop .rc_vivid_mute_loop
   456                                  
   457                                  .rc_pop_check:
   458                                      ; Step 3: Pop = saturation boost + contrast boost
   459 00000290 2E803E[1500]00              cmp byte [cs:adj_pop], 0
   460 00000296 7406                        je .rc_brightness
   461 00000298 E8CD01                      call res_saturation_boost
   462 0000029B E84302                      call res_contrast_boost
   463                                  
   464                                  .rc_brightness:
   465                                      ; Step 4: Brightness (-3..+3 steps, each step = ±8)
   466 0000029E 2EA0[1300]                  mov al, [cs:adj_brightness]
   467 000002A2 84C0                        test al, al
   468 000002A4 7418                        jz .rc_apply
   469 000002A6 780B                        js .rc_dim
   470                                      ; Positive: brighten
   471 000002A8 88C1                        mov cl, al
   472 000002AA 30ED                        xor ch, ch
   473                                  .rc_bright_loop:
   474 000002AC E88301                      call res_brighten
   475 000002AF E2FB                        loop .rc_bright_loop
   476 000002B1 EB0B                        jmp .rc_apply
   477                                  .rc_dim:
   478 000002B3 F6D8                        neg al
   479 000002B5 88C1                        mov cl, al
   480 000002B7 30ED                        xor ch, ch
   481                                  .rc_dim_loop:
   482 000002B9 E89201                      call res_dim
   483 000002BC E2FB                        loop .rc_dim_loop
   484                                  
   485                                  .rc_apply:
   486                                      ; Step 5: Rebuild EGA shadow if needed, then write to hardware
   487 000002BE 2E803E[1200]02              cmp byte [cs:video_type], 2
   488 000002C4 740A                        je .rc_vga
   489 000002C6 2E803E[1200]01              cmp byte [cs:video_type], 1
   490 000002CC 7407                        je .rc_ega
   491 000002CE EB0B                        jmp .rc_done
   492                                  
   493                                  .rc_vga:
   494 000002D0 E81000                      call apply_palette_vga
   495 000002D3 EB06                        jmp .rc_done
   496                                  
   497                                  .rc_ega:
   498 000002D5 E8AB00                      call res_build_ega_shadow
   499 000002D8 E88000                      call apply_palette_ega
   500                                  
   501                                  .rc_done:
   502 000002DB 07                          pop es
   503 000002DC 5F                          pop di
   504 000002DD 5E                          pop si
   505 000002DE 5A                          pop dx
   506 000002DF 59                          pop cx
   507 000002E0 5B                          pop bx
   508 000002E1 58                          pop ax
   509 000002E2 C3                          ret
   510                                  
   511                                  ; ============================================================================
   512                                  ; apply_palette_vga — Table-driven VGA DAC write + ATC programming
   513                                  ; Reads from palette_rgb[], uses color_to_dac[] for mapping.
   514                                  ; All addresses via CS: since this runs from the TSR.
   515                                  ; ============================================================================
   516                                  apply_palette_vga:
   517 000002E3 50                          push ax
   518 000002E4 53                          push bx
   519 000002E5 51                          push cx
   520 000002E6 52                          push dx
   521 000002E7 56                          push si
   522 000002E8 57                          push di
   523                                  
   524                                      ; Build 48-byte DAC table from palette_rgb using color_to_dac mapping
   525 000002E9 BE[3E00]                    mov si, color_to_dac
   526 000002EC BF[B600]                    mov di, dac_table
   527 000002EF B91000                      mov cx, 16
   528                                  .build_dac:
   529 000002F2 2E8A04                      mov al, [cs:si]            ; AL = user color index (0-3)
   530 000002F5 46                          inc si
   531                                      ; Multiply by 3 for palette_rgb offset
   532 000002F6 88C3                        mov bl, al
   533 000002F8 D0E3                        shl bl, 1
   534 000002FA 00C3                        add bl, al                 ; BL = index * 3
   535 000002FC 30FF                        xor bh, bh
   536 000002FE 2E8A87[2200]                mov al, [cs:palette_rgb + bx]
   537 00000303 2E8805                      mov [cs:di], al
   538 00000306 2E8A87[2300]                mov al, [cs:palette_rgb + bx + 1]
   539 0000030B 2E884501                    mov [cs:di + 1], al
   540 0000030F 2E8A87[2400]                mov al, [cs:palette_rgb + bx + 2]
   541 00000314 2E884502                    mov [cs:di + 2], al
   542 00000318 83C703                      add di, 3
   543 0000031B E2D5                        loop .build_dac
   544                                  
   545                                      ; Write all 16 DAC entries starting at index 0
   546 0000031D BAC803                      mov dx, VGA_DAC_WRITE_IDX
   547 00000320 30C0                        xor al, al
   548 00000322 EE                          out dx, al
   549 00000323 BE[B600]                    mov si, dac_table
   550 00000326 B93000                      mov cx, 48
   551 00000329 BAC903                      mov dx, VGA_DAC_DATA
   552                                  .write_dac:
   553 0000032C 2E8A04                      mov al, [cs:si]
   554 0000032F 46                          inc si
   555 00000330 EE                          out dx, al
   556 00000331 E2F9                        loop .write_dac
   557                                  
   558                                      ; Program ATC[0-15] for conflict-free routing
   559 00000333 FA                          cli
   560 00000334 BADA03                      mov dx, INPUT_STATUS_1
   561 00000337 EC                          in al, dx                  ; Reset ATC flip-flop
   562                                  
   563 00000338 31DB                        xor bx, bx
   564                                  .write_atc:
   565 0000033A BAC003                      mov dx, ATC_ADDR_DATA
   566 0000033D 88D8                        mov al, bl
   567 0000033F EE                          out dx, al
   568 00000340 EB00                        jmp short $+2
   569 00000342 2E8A87[4E00]                mov al, [cs:vga_atc_init + bx]
   570 00000347 EE                          out dx, al
   571 00000348 EB00                        jmp short $+2
   572 0000034A 43                          inc bx
   573 0000034B 83FB10                      cmp bx, 16
   574 0000034E 72EA                        jb .write_atc
   575                                  
   576 00000350 B020                        mov al, 0x20               ; Re-enable screen
   577 00000352 EE                          out dx, al
   578 00000353 FB                          sti
   579                                  
   580 00000354 5F                          pop di
   581 00000355 5E                          pop si
   582 00000356 5A                          pop dx
   583 00000357 59                          pop cx
   584 00000358 5B                          pop bx
   585 00000359 58                          pop ax
   586 0000035A C3                          ret
   587                                  
   588                                  ; ============================================================================
   589                                  ; apply_palette_ega — Write 16-entry atc_shadow[] to EGA ATC ports
   590                                  ; ============================================================================
   591                                  apply_palette_ega:
   592 0000035B 50                          push ax
   593 0000035C 53                          push bx
   594 0000035D 52                          push dx
   595                                  
   596 0000035E FA                          cli
   597 0000035F BADA03                      mov dx, INPUT_STATUS_1
   598 00000362 EC                          in al, dx
   599                                  
   600 00000363 31DB                        xor bx, bx
   601                                  .ega_loop:
   602 00000365 BAC003                      mov dx, ATC_ADDR_DATA
   603 00000368 88D8                        mov al, bl
   604 0000036A EE                          out dx, al
   605 0000036B EB00                        jmp short $+2
   606 0000036D 2E8A87[2E00]                mov al, [cs:atc_shadow + bx]
   607 00000372 EE                          out dx, al
   608 00000373 EB00                        jmp short $+2
   609 00000375 43                          inc bx
   610 00000376 83FB10                      cmp bx, 16
   611 00000379 72EA                        jb .ega_loop
   612                                  
   613 0000037B B020                        mov al, 0x20
   614 0000037D EE                          out dx, al
   615 0000037E FB                          sti
   616                                  
   617 0000037F 5A                          pop dx
   618 00000380 5B                          pop bx
   619 00000381 58                          pop ax
   620 00000382 C3                          ret
   621                                  
   622                                  ; ============================================================================
   623                                  ; res_build_ega_shadow — Convert palette_rgb to EGA values, fill atc_shadow
   624                                  ; ============================================================================
   625                                  res_build_ega_shadow:
   626 00000383 50                          push ax
   627 00000384 53                          push bx
   628 00000385 51                          push cx
   629 00000386 56                          push si
   630 00000387 57                          push di
   631                                  
   632                                      ; Start with CGA defaults
   633 00000388 BE[5E00]                    mov si, cga_ega_default
   634 0000038B BF[2E00]                    mov di, atc_shadow
   635 0000038E B91000                      mov cx, 16
   636                                  .copy_defaults:
   637 00000391 2E8A04                      mov al, [cs:si]
   638 00000394 2E8805                      mov [cs:di], al
   639 00000397 46                          inc si
   640 00000398 47                          inc di
   641 00000399 E2F6                        loop .copy_defaults
   642                                  
   643                                      ; Convert 4 RGB colors to EGA 6-bit values in ega_tmp
   644 0000039B BE[2200]                    mov si, palette_rgb
   645 0000039E BF[E600]                    mov di, ega_tmp
   646 000003A1 B90400                      mov cx, 4
   647                                  .conv_loop:
   648 000003A4 30DB                        xor bl, bl
   649 000003A6 2E8A04                      mov al, [cs:si]            ; Red
   650 000003A9 46                          inc si
   651 000003AA 3C20                        cmp al, 32
   652 000003AC 7205                        jb .r_half
   653 000003AE 80CB04                      or bl, 0x04
   654 000003B1 EB07                        jmp .r_done
   655                                  .r_half:
   656 000003B3 3C10                        cmp al, 16
   657 000003B5 7203                        jb .r_done
   658 000003B7 80CB20                      or bl, 0x20
   659                                  .r_done:
   660 000003BA 2E8A04                      mov al, [cs:si]            ; Green
   661 000003BD 46                          inc si
   662 000003BE 3C20                        cmp al, 32
   663 000003C0 7205                        jb .g_half
   664 000003C2 80CB02                      or bl, 0x02
   665 000003C5 EB07                        jmp .g_done
   666                                  .g_half:
   667 000003C7 3C10                        cmp al, 16
   668 000003C9 7203                        jb .g_done
   669 000003CB 80CB10                      or bl, 0x10
   670                                  .g_done:
   671 000003CE 2E8A04                      mov al, [cs:si]            ; Blue
   672 000003D1 46                          inc si
   673 000003D2 3C20                        cmp al, 32
   674 000003D4 7205                        jb .b_half
   675 000003D6 80CB01                      or bl, 0x01
   676 000003D9 EB07                        jmp .b_done
   677                                  .b_half:
   678 000003DB 3C10                        cmp al, 16
   679 000003DD 7203                        jb .b_done
   680 000003DF 80CB08                      or bl, 0x08
   681                                  .b_done:
   682 000003E2 2E881D                      mov [cs:di], bl
   683 000003E5 47                          inc di
   684 000003E6 E2BC                        loop .conv_loop
   685                                  
   686                                      ; Place EGA values into atc_shadow at all CGA mode 4 positions
   687 000003E8 2EA0[E600]                  mov al, [cs:ega_tmp+0]
   688 000003EC 2EA2[2E00]                  mov [cs:atc_shadow+0], al
   689                                  
   690 000003F0 2EA0[E700]                  mov al, [cs:ega_tmp+1]
   691 000003F4 2EA2[3000]                  mov [cs:atc_shadow+2], al
   692 000003F8 2EA2[3100]                  mov [cs:atc_shadow+3], al
   693 000003FC 2EA2[3800]                  mov [cs:atc_shadow+10], al
   694 00000400 2EA2[3900]                  mov [cs:atc_shadow+11], al
   695                                  
   696 00000404 2EA0[E800]                  mov al, [cs:ega_tmp+2]
   697 00000408 2EA2[3200]                  mov [cs:atc_shadow+4], al
   698 0000040C 2EA2[3300]                  mov [cs:atc_shadow+5], al
   699 00000410 2EA2[3A00]                  mov [cs:atc_shadow+12], al
   700 00000414 2EA2[3B00]                  mov [cs:atc_shadow+13], al
   701                                  
   702 00000418 2EA0[E900]                  mov al, [cs:ega_tmp+3]
   703 0000041C 2EA2[3400]                  mov [cs:atc_shadow+6], al
   704 00000420 2EA2[3500]                  mov [cs:atc_shadow+7], al
   705 00000424 2EA2[3C00]                  mov [cs:atc_shadow+14], al
   706 00000428 2EA2[3D00]                  mov [cs:atc_shadow+15], al
   707                                  
   708 0000042C 5F                          pop di
   709 0000042D 5E                          pop si
   710 0000042E 59                          pop cx
   711 0000042F 5B                          pop bx
   712 00000430 58                          pop ax
   713 00000431 C3                          ret
   714                                  
   715                                  ; ============================================================================
   716                                  ; RESIDENT ADJUSTMENT ROUTINES
   717                                  ; These operate on palette_rgb (colors 1-3 only, skip background at offset 0).
   718                                  ; All use CS: segment override since they run from the TSR.
   719                                  ; ============================================================================
   720                                  
   721                                  ; --- res_brighten: Add 8 to each RGB channel, clamp at 63 ---
   722                                  res_brighten:
   723 00000432 51                          push cx
   724 00000433 56                          push si
   725 00000434 BE[2500]                    mov si, palette_rgb + 3    ; skip color 0
   726 00000437 B90900                      mov cx, 9
   727                                  .loop:
   728 0000043A 2E8A04                      mov al, [cs:si]
   729 0000043D 0408                        add al, 8
   730 0000043F 3C3F                        cmp al, 63
   731 00000441 7602                        jbe .ok
   732 00000443 B03F                        mov al, 63
   733                                  .ok:
   734 00000445 2E8804                      mov [cs:si], al
   735 00000448 46                          inc si
   736 00000449 E2EF                        loop .loop
   737 0000044B 5E                          pop si
   738 0000044C 59                          pop cx
   739 0000044D C3                          ret
   740                                  
   741                                  ; --- res_dim: Subtract 8 from each RGB channel, clamp at 0 ---
   742                                  res_dim:
   743 0000044E 51                          push cx
   744 0000044F 56                          push si
   745 00000450 BE[2500]                    mov si, palette_rgb + 3
   746 00000453 B90900                      mov cx, 9
   747                                  .loop:
   748 00000456 2E8A04                      mov al, [cs:si]
   749 00000459 2C08                        sub al, 8
   750 0000045B 7302                        jnc .ok
   751 0000045D 30C0                        xor al, al
   752                                  .ok:
   753 0000045F 2E8804                      mov [cs:si], al
   754 00000462 46                          inc si
   755 00000463 E2F1                        loop .loop
   756 00000465 5E                          pop si
   757 00000466 59                          pop cx
   758 00000467 C3                          ret
   759                                  
   760                                  ; --- res_saturation_boost: ch + (ch - gray) / 2, clamp 0-63 ---
   761                                  res_saturation_boost:
   762 00000468 53                          push bx
   763 00000469 51                          push cx
   764 0000046A 56                          push si
   765 0000046B BE[2500]                    mov si, palette_rgb + 3
   766 0000046E B90300                      mov cx, 3                  ; 3 color triples
   767                                  .color:
   768 00000471 31C0                        xor ax, ax
   769 00000473 2E8A04                      mov al, [cs:si]
   770 00000476 2E024401                    add al, [cs:si+1]
   771 0000047A 2E024402                    add al, [cs:si+2]         ; AL = R+G+B
   772 0000047E B303                        mov bl, 3
   773 00000480 F6F3                        div bl                     ; AL = gray
   774 00000482 88C3                        mov bl, al                 ; BL = gray
   775                                  
   776 00000484 51                          push cx
   777 00000485 B90300                      mov cx, 3
   778                                  .ch:
   779 00000488 2E8A04                      mov al, [cs:si]
   780 0000048B 28D8                        sub al, bl                 ; AL = ch - gray (signed)
   781 0000048D D0F8                        sar al, 1                 ; AL = (ch - gray) / 2
   782 0000048F 2E0204                      add al, [cs:si]           ; AL = ch + (ch - gray) / 2
   783 00000492 84C0                        test al, al
   784 00000494 7904                        jns .not_neg
   785 00000496 30C0                        xor al, al
   786 00000498 EB06                        jmp .store
   787                                  .not_neg:
   788 0000049A 3C3F                        cmp al, 63
   789 0000049C 7602                        jbe .store
   790 0000049E B03F                        mov al, 63
   791                                  .store:
   792 000004A0 2E8804                      mov [cs:si], al
   793 000004A3 46                          inc si
   794 000004A4 E2E2                        loop .ch
   795 000004A6 59                          pop cx
   796 000004A7 E2C8                        loop .color
   797 000004A9 5E                          pop si
   798 000004AA 59                          pop cx
   799 000004AB 5B                          pop bx
   800 000004AC C3                          ret
   801                                  
   802                                  ; --- res_saturation_mute: (ch + gray) / 2 ---
   803                                  res_saturation_mute:
   804 000004AD 53                          push bx
   805 000004AE 51                          push cx
   806 000004AF 56                          push si
   807 000004B0 BE[2500]                    mov si, palette_rgb + 3
   808 000004B3 B90300                      mov cx, 3
   809                                  .color:
   810 000004B6 31C0                        xor ax, ax
   811 000004B8 2E8A04                      mov al, [cs:si]
   812 000004BB 2E024401                    add al, [cs:si+1]
   813 000004BF 2E024402                    add al, [cs:si+2]
   814 000004C3 B303                        mov bl, 3
   815 000004C5 F6F3                        div bl
   816 000004C7 88C3                        mov bl, al                 ; BL = gray
   817                                  
   818 000004C9 51                          push cx
   819 000004CA B90300                      mov cx, 3
   820                                  .ch:
   821 000004CD 2E8A04                      mov al, [cs:si]
   822 000004D0 00D8                        add al, bl
   823 000004D2 D0E8                        shr al, 1                 ; (ch + gray) / 2
   824 000004D4 2E8804                      mov [cs:si], al
   825 000004D7 46                          inc si
   826 000004D8 E2F3                        loop .ch
   827 000004DA 59                          pop cx
   828 000004DB E2D9                        loop .color
   829 000004DD 5E                          pop si
   830 000004DE 59                          pop cx
   831 000004DF 5B                          pop bx
   832 000004E0 C3                          ret
   833                                  
   834                                  ; --- res_contrast_boost: ch + (ch - 31) / 2, clamp 0-63 ---
   835                                  res_contrast_boost:
   836 000004E1 51                          push cx
   837 000004E2 56                          push si
   838 000004E3 BE[2500]                    mov si, palette_rgb + 3
   839 000004E6 B90900                      mov cx, 9
   840                                  .loop:
   841 000004E9 2E8A04                      mov al, [cs:si]
   842 000004EC 2C1F                        sub al, 31                 ; signed
   843 000004EE D0F8                        sar al, 1
   844 000004F0 2E0204                      add al, [cs:si]
   845 000004F3 84C0                        test al, al
   846 000004F5 7904                        jns .not_neg
   847 000004F7 30C0                        xor al, al
   848 000004F9 EB06                        jmp .store
   849                                  .not_neg:
   850 000004FB 3C3F                        cmp al, 63
   851 000004FD 7602                        jbe .store
   852 000004FF B03F                        mov al, 63
   853                                  .store:
   854 00000501 2E8804                      mov [cs:si], al
   855 00000504 46                          inc si
   856 00000505 E2E2                        loop .loop
   857 00000507 5E                          pop si
   858 00000508 59                          pop cx
   859 00000509 C3                          ret
   860                                  
   861                                  ; ============================================================================
   862                                  ; End of resident section
   863                                  ; ============================================================================
   864                                  tsr_end:
