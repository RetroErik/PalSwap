  1094                                  ; detect_video — Set [video_type]: 0=none, 1=EGA, 2=VGA
  1095                                  ; ============================================================================
  1096                                  detect_video:
  1097 000006AC 50                          push ax
  1098 000006AD 53                          push bx
  1099 000006AE 51                          push cx
  1100                                  
  1101                                      ; Try VGA first (INT 10h AX=1A00h)
  1102 000006AF B8001A                      mov ax, 0x1A00
  1103 000006B2 CD10                        int 0x10
