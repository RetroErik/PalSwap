   872                                  ; ============================================================================
   873                                  ; Main installer entry point
   874                                  ; ============================================================================
   875                                  main:
   876 0000050A BA[360E]                    mov dx, msg_banner
   877 0000050D E81F09                      call print_string
   878                                  
   879                                      ; Detect EGA/VGA
   880 00000510 E89901                      call detect_video
   881 00000513 803E[1200]00                cmp byte [video_type], 0
   882 00000518 743E                        je .no_adapter
   883                                  
   884                                      ; Check for /U (uninstall) first
   885 0000051A E87402                      call check_uninstall
   886 0000051D 3C01                        cmp al, 1
   887 0000051F 7503E97E01                  je .do_uninstall
   888                                  
   889                                      ; Parse all command-line switches
   890 00000524 E89202                      call check_switches
   891 00000527 50                          push ax                    ; save switch result
   892 00000528 E8EC03                      call parse_bg_color
   893 0000052B E89204                      call parse_fg_colors
   894 0000052E 58                          pop ax
   895 0000052F 803E[BF18]00                cmp byte [parse_error], 0
   896 00000534 7403E96E01                  jne .exit_no_tsr
   897 00000539 3C01                        cmp al, 1
   898 0000053B 7424                        je .show_help
   899 0000053D 3C02                        cmp al, 2
   900 0000053F 7445                        je .do_reset_install
   901 00000541 3C03                        cmp al, 3
   902 00000543 744C                        je .preset_1
   903 00000545 3C04                        cmp al, 4
   904 00000547 7453                        je .preset_2
   905 00000549 3C05                        cmp al, 5
   906 0000054B 745A                        je .preset_3
   907 0000054D 3C06                        cmp al, 6
   908 0000054F 7461                        je .preset_4
   909 00000551 3C07                        cmp al, 7
   910 00000553 7468                        je .preset_5
   911 00000555 E98400                      jmp .load_file
   912                                  
   913                                  .no_adapter:
   914 00000558 BA[240F]                    mov dx, msg_no_adapter
   915 0000055B E8D108                      call print_string
   916 0000055E E94601                      jmp .exit_no_tsr
   917                                  
   918                                  .show_help:
   919 00000561 BA[4D0F]                    mov dx, msg_help
   920 00000564 E8C808                      call print_string
   921 00000567 BA[F711]                    mov dx, msg_pause
   922 0000056A E8C208                      call print_string
   923                                  .flush_kb:
   924 0000056D B401                        mov ah, 0x01
   925 0000056F CD16                        int 0x16
   926 00000571 7406                        jz .wait_key
   927 00000573 B400                        mov ah, 0x00
   928 00000575 CD16                        int 0x16
   929 00000577 EBF4                        jmp .flush_kb
   930                                  .wait_key:
   931 00000579 B400                        mov ah, 0x00
   932 0000057B CD16                        int 0x16
   933 0000057D BA[1812]                    mov dx, msg_help2
   934 00000580 E8AC08                      call print_string
   935 00000583 E92101                      jmp .exit_no_tsr
   936                                  
   937                                  .do_reset_install:
   938 00000586 BA[4315]                    mov dx, msg_resetting
   939 00000589 E8A308                      call print_string
   940                                      ; Load fallback palette as base
   941 0000058C BE[6E00]                    mov si, res_preset_fallback
   942 0000058F EB37                        jmp .apply_preset
   943                                  
   944                                  .preset_1:
   945 00000591 BA[BF14]                    mov dx, msg_preset1
   946 00000594 E89808                      call print_string
   947 00000597 BE[7A00]                    mov si, res_preset_1
   948 0000059A EB2C                        jmp .apply_preset
   949                                  .preset_2:
   950 0000059C BA[D814]                    mov dx, msg_preset2
   951 0000059F E88D08                      call print_string
   952 000005A2 BE[8600]                    mov si, res_preset_2
   953 000005A5 EB21                        jmp .apply_preset
   954                                  .preset_3:
   955 000005A7 BA[F114]                    mov dx, msg_preset3
   956 000005AA E88208                      call print_string
   957 000005AD BE[9200]                    mov si, res_preset_3
   958 000005B0 EB16                        jmp .apply_preset
   959                                  .preset_4:
   960 000005B2 BA[0815]                    mov dx, msg_preset4
   961 000005B5 E87708                      call print_string
   962 000005B8 BE[9E00]                    mov si, res_preset_4
   963 000005BB EB0B                        jmp .apply_preset
   964                                  .preset_5:
   965 000005BD BA[2615]                    mov dx, msg_preset5
   966 000005C0 E86C08                      call print_string
   967 000005C3 BE[AA00]                    mov si, res_preset_5
   968 000005C6 EB00                        jmp .apply_preset
   969                                  
   970                                  .apply_preset:
   971                                      ; Copy 12 bytes from preset to config_buffer
   972 000005C8 BF[5719]                    mov di, config_buffer
   973 000005CB B90C00                      mov cx, 12
   974 000005CE FC                          cld
   975 000005CF F3A4                        rep movsb
