  1152                                  ; ============================================================================
  1153                                  ; check_already_loaded — AL=1 if TSR signature found at INT 10h handler
  1154                                  ; ============================================================================
  1155                                  check_already_loaded:
  1156 00000706 53                          push bx
  1157 00000707 51                          push cx
  1158 00000708 56                          push si
  1159 00000709 57                          push di
  1160 0000070A 06                          push es
  1161                                  
  1162                                      ; Get current INT 10h vector
  1163 0000070B B81035                      mov ax, 0x3510
