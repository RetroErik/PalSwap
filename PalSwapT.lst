  1165                                      ; ES:BX → current INT 10h handler
  1166                                      ; Check if it points to our signature
  1167                                      ; Our TSR has: jmp main, then tsr_sig at known offset
  1168                                      ; The signature 'PalSwap' is at tsr_sig in seg pointed to by ES
  1169 00000710 BF[0300]                    mov di, tsr_sig             ; offset of signature in our code
  1170 00000713 BE[0300]                    mov si, tsr_sig             ; compare against our own copy
  1171 00000716 B90700                      mov cx, 7
  1172 00000719 1E                          push ds
  1173 0000071A 0E                          push cs
  1174 0000071B 1F                          pop ds                     ; DS:SI = CS:tsr_sig
  1175 0000071C F3A6                        repe cmpsb                 ; compare ES:DI vs DS:SI
  1176 0000071E 1F                          pop ds
  1177 0000071F 7504                        jne .not_loaded
  1178                                  
  1179 00000721 B001                        mov al, 1
  1180 00000723 EB02                        jmp .cal_done
  1181                                  
  1182                                  .not_loaded:
  1183 00000725 30C0                        xor al, al
  1184                                  
  1185                                  .cal_done:
  1186 00000727 07                          pop es
  1187 00000728 5F                          pop di
  1188 00000729 5E                          pop si
  1189 0000072A 59                          pop cx
  1190 0000072B 5B                          pop bx
  1191 0000072C C3                          ret
  1192                                  
  1193                                  ; ============================================================================
  1194                                  ; uninstall_tsr — Restore original INT 09h + INT 10h, free TSR memory
  1195                                  ; ============================================================================
  1196                                  uninstall_tsr:
  1197 0000072D 50                          push ax
  1198 0000072E 53                          push bx
  1199 0000072F 52                          push dx
