  1206                                      ; ES:BX → current handler; verify signature
  1207 00000737 BF[0300]                    mov di, tsr_sig
  1208 0000073A BE[0300]                    mov si, tsr_sig
  1209 0000073D B90700                      mov cx, 7
  1210 00000740 1E                          push ds
  1211 00000741 0E                          push cs
  1212 00000742 1F                          pop ds
  1213 00000743 F3A6                        repe cmpsb
  1214 00000745 1F                          pop ds
  1215 00000746 753B                        jne .not_us
  1216                                  
  1217                                      ; ES = TSR segment. Restore original INT 10h from TSR's saved values.
  1218 00000748 B81025                      mov ax, 0x2510
