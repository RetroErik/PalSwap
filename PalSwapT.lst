  1107 000006BB 7433                        je .is_vga
  1108 000006BD 80FB07                      cmp bl, 0x07               ; VGA analog mono
  1109 000006C0 742E                        je .is_vga
  1110                                  
  1111                                  .try_ega:
  1112 000006C2 B80012                      mov ax, 0x1200
  1113 000006C5 B310                        mov bl, 0x10
